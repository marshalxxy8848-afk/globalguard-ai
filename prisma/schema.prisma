generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  audits       AuditRecord[]
}

model AuditRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productName String
  hsCode      String
  riskLevel   String
  report      String   // JSON string of the full audit report
  createdAt   DateTime @default(now())

  @@index([userId])
}
